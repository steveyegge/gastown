{
    "_comment": "Rig-level settings: ~/gt/<rig>/settings/config.json",
    "_comment2": "Overrides town-level agent/role settings for this specific rig.",
    "_comment3": "Only include fields you want to override — omitted fields inherit from town settings.",
    "_comment4": "repo_contract usually lives in the committed repo file .gastown/settings.json; including it here overrides those repo defaults locally.",

    "type": "rig-settings",
    "version": 1,

    "agent": "pi",

    "agents": {
        "rig-specific-agent": {
            "command": "claude",
            "args": ["--model", "sonnet", "--dangerously-skip-permissions"],
            "env": {
                "CLAUDECODE": ""
            }
        }
    },

    "role_agents": {
        "polecat":  "pi",
        "witness":  "pi",
        "refinery": "pi"
    },

    "merge_queue": {
        "enabled": true,
        "integration_branch_polecat_enabled": true,
        "integration_branch_refinery_enabled": true,
        "integration_branch_template": "integration/{epic}",
        "integration_branch_auto_land": false,
        "on_conflict": "assign_back",
        "verification_mode": "strict",
        "run_tests": true,
        "test_command": "",
        "build_command": "go build ./...",
        "lint_command": "golangci-lint run",
        "setup_command": "",
        "typecheck_command": "",
        "gates": {
            "verify": {"cmd": "./scripts/ci/verify.sh", "timeout": "10m"},
            "smoke-post-squash": {"cmd": "make ci-smoke", "timeout": "2m", "phase": "post-squash"}
        },
        "gates_parallel": true,
        "auto_push": true,
        "delete_merged_branches": true,
        "retry_flaky_tests": 1,
        "poll_interval": "30s",
        "max_concurrent": 1,
        "stale_claim_timeout": "30m"
    },

    "repo_contract": {
        "repo_type": "backend-api",
        "enforcement_tier": "production",
        "verify_command": "./scripts/ci/verify.sh",
        "smoke_command": "./scripts/ci/smoke.sh",
        "release_check_command": "./scripts/ci/release-check.sh",
        "e2e_command": "./scripts/ci/e2e.sh",
        "perf_command": "./scripts/ci/perf.sh",
        "requires_migrations": true,
        "requires_e2e": true,
        "requires_security_scan": true,
        "critical_paths": [
            "signup and login",
            "checkout and payment",
            "background job retry"
        ]
    },

    "theme": {
        "disabled": false,
        "name": "ocean",
        "custom": {
            "bg": "#111111",
            "fg": "#eeeeee"
        },
        "role_themes": {
            "witness": "rust",
            "refinery": "plum",
            "crew": "none"
        }
    },

    "namepool": {
        "style": "minerals"
    },

    "crew": {
        "startup": "none"
    },

    "workflow": {
        "default_formula": "mol-polecat-work"
    }
}
