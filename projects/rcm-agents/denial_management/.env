# Denial Management Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit real credentials to source control.

# Azure OpenAI Endpoint
# Options:
#   A) Azure OpenAI resource: https://<resource-name>.openai.azure.com/
#   B) Azure AI Foundry project (AOAI-compatible): https://<account>.openai.azure.com/
# Find in: Azure Portal → Azure OpenAI resource → Overview → Endpoint
#      OR: AI Foundry Portal → Project → Overview → Azure OpenAI Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/

# Model deployment name in your Azure OpenAI / Foundry resource
# Recommended: gpt-4.1  (strong multi-step reasoning + 1M context for RCM workflows)
# Also works:  gpt-5.1, gpt-4o
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# Optional: Foundry Project Endpoint (for future AzureAIClient use when SDK deps stabilize)
# FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<id>
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.1
