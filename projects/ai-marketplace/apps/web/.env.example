# ── Next.js App Environment Variables (Example) ──────────────────────────────
# Copy this to .env.local and fill in your values

API_BASE_URL=http://localhost:7071/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:7071/api

AZURE_CLIENT_ID=<your-entra-app-client-id>
AZURE_TENANT_ID=<your-entra-tenant-id>
NEXT_PUBLIC_AZURE_CLIENT_ID=<your-entra-app-client-id>
NEXT_PUBLIC_AZURE_TENANT_ID=<your-entra-tenant-id>

COSMOS_ENDPOINT=https://localhost:8081/
COSMOS_KEY=<cosmos-primary-key>
COSMOS_DATABASE=ai-marketplace

APPLICATIONINSIGHTS_CONNECTION_STRING=<app-insights-connection-string>

# ── Azure ML Workspace ────────────────────────────────────────────────────────
# Required for IMDE sandbox/compute integration (Manage Compute, New Sandbox, live status)
AZURE_SUBSCRIPTION_ID=a7fecb91-4553-4aca-976e-274add998c8d
AZURE_ML_RESOURCE_GROUP=rg-ai-marketplace-dev
# Azure ML project workspace name (AI Foundry project)
AZURE_ML_WORKSPACE=ai-project-q2w5uxlkh4c6o
# Azure AI Foundry — Model Card integration
# AI Services project endpoint (supports: deployments, agents)
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project-name>

# AI Hub workspace endpoint (required ONLY for live evaluation run data)
# Evaluations are NOT available on the AI Services endpoint above.
# Format: https://{region}.api.azureml.ms/raisvc/v1.0/subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.MachineLearningServices/workspaces/{hub-workspace}
AZURE_AI_HUB_WORKSPACE_URL=

# Azure AD service principal (used for Foundry auth)
AZURE_AD_CLIENT_ID=<service-principal-client-id>
AZURE_AD_CLIENT_SECRET=<service-principal-client-secret>
AZURE_AD_TENANT_ID=<azure-ad-tenant-id>