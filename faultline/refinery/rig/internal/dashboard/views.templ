	case "dispatched":
		return "Polecat dispatched to fix"
	case "notified":
		return "Crew notified (auto-sling failed)"
	case "regression":
		return "Regression — error reappeared after fix"
	case "resolved":
		return "Resolved — fix confirmed, error quiet"
	case "escalation":
