      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM hq.dependencies d JOIN hq.issues c ON d.issue_id = c.id WHERE c.issue_type = 'convoy' AND c.status NOT IN ('closed','completed') AND d.type = 'tracks'"
        }
