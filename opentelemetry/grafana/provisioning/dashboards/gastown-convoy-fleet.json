        "w": 4,
        "x": 20,
        "y": 24
      },
      "id": 8,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT SUBSTRING_INDEX(SUBSTRING_INDEX(d.depends_on_id, ':', 2), ':', -1)) AS value FROM hq.dependencies d JOIN hq.issues c ON d.issue_id = c.id WHERE c.issue_type = 'convoy' AND c.status NOT IN ('closed','completed') AND d.type = 'tracks' AND d.depends_on_id LIKE 'external:%'"
        }
      ],
      "title": "Rigs Touched",
      "type": "stat"
    }
