      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM hq.issues WHERE issue_type = 'convoy' AND status IN ('closed','completed') AND updated_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY)"
        }
