{
  "panels": [
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Convoy Detail",
                    "url": "/d/gastown-convoy-preview/convoy-preview?var-database=hq\u0026var-convoy_id=${__value.raw}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "closed": {
                        "color": "green",
                        "text": "closed"
                      },
                      "in_progress": {
                        "color": "orange",
                        "text": "in_progress"
                      },
                      "open": {
                        "color": "blue",
                        "text": "open"
                      },
                      "staged_ready": {
                        "color": "purple",
                        "text": "staged_ready"
                      },
                      "staged_warnings": {
                        "color": "yellow",
                        "text": "staged_warnings"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "status"
          }
        ]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT c.id, c.title, c.status, c.priority, COALESCE(NULLIF(c.assignee,''),'—') AS owner, c.created_at, DATEDIFF(NOW(), c.created_at) AS age_days, (SELECT COUNT(*) FROM hq.dependencies d WHERE d.issue_id = c.id AND d.type = 'tracks') AS tracked, (SELECT COUNT(*) FROM hq.dependencies d WHERE d.issue_id = c.id AND d.type = 'tracks' AND SUBSTRING_INDEX(d.depends_on_id, ':', -1) IN (SELECT id FROM hq.issues WHERE status IN ('closed','completed'))) AS done, (SELECT COUNT(*) FROM hq.dependencies d WHERE d.issue_id = c.id AND d.type = 'tracks' AND SUBSTRING_INDEX(d.depends_on_id, ':', -1) IN (SELECT id FROM hq.issues WHERE status = 'in_progress')) AS active, (SELECT GROUP_CONCAT(DISTINCT SUBSTRING_INDEX(SUBSTRING_INDEX(d.depends_on_id, ':', 2), ':', -1) ORDER BY 1 SEPARATOR ', ') FROM hq.dependencies d WHERE d.issue_id = c.id AND d.type = 'tracks' AND d.depends_on_id LIKE 'external:%') AS rigs FROM hq.issues c WHERE c.issue_type = 'convoy' ORDER BY CASE WHEN c.status IN ('open','in_progress','staged_ready') THEN 0 ELSE 1 END, c.priority ASC, c.created_at DESC"
        }
      ],
      "title": "All Convoys",
      "type": "table"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "convoy"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Convoy Detail",
                    "url": "/d/gastown-convoy-preview/convoy-preview?var-database=hq\u0026var-convoy_id=${__value.raw}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "epic_status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "closed": {
                        "color": "green",
                        "text": "closed"
                      },
                      "in_progress": {
                        "color": "orange",
                        "text": "in_progress"
                      },
                      "open": {
                        "color": "blue",
                        "text": "open"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 7,
      "maxPerRow": 1,
      "options": {
        "showHeader": true
      },
      "repeat": "database",
      "repeatDirection": "v",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT c.id AS convoy, LEFT(c.title, 40) AS convoy_title, c.status AS convoy_status, SUBSTRING_INDEX(d.depends_on_id, ':', -1) AS item_id, i.title AS item_title, i.issue_type, i.status AS item_status, i.priority FROM hq.dependencies d JOIN hq.issues c ON d.issue_id = c.id JOIN ${database:raw}.issues i ON i.id = SUBSTRING_INDEX(d.depends_on_id, ':', -1) WHERE c.issue_type = 'convoy' AND d.type = 'tracks' AND d.depends_on_id LIKE CONCAT('external:', '${database:raw}', ':%') ORDER BY CASE WHEN c.status IN ('open','in_progress','staged_ready') THEN 0 ELSE 1 END, c.status, i.priority ASC"
        }
      ],
      "title": "Tracked Items — ${database}",
      "type": "table"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 24
      },
      "id": 2,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM hq.issues WHERE issue_type = 'convoy' AND status NOT IN ('closed','completed')"
        }
      ],
      "title": "Open",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
