      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT design FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "design"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 800
              }
