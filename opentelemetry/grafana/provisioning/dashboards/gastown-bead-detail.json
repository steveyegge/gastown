{
  "uid": "gastown-bead-detail",
  "title": "Bead Detail",
  "tags": [
    "gastown",
    "beads"
  ],
  "timezone": "browser",
  "refresh": "",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "database",
        "type": "query",
        "query": "SELECT DISTINCT TABLE_SCHEMA AS __value, TABLE_SCHEMA AS __text FROM information_schema.TABLES WHERE TABLE_NAME = 'issues' ORDER BY TABLE_SCHEMA",
        "includeAll": false,
        "current": {
          "text": "hq",
          "value": "hq"
        },
        "label": "Rig Database",
        "datasource": {
          "uid": "dolt-beads"
        },
        "refresh": 1,
        "multi": false
      },
      {
        "name": "filter",
        "label": "Show",
        "type": "custom",
        "query": "all,convoy,epic,task,bug,feature,agent",
        "includeAll": false,
        "current": {
          "text": "all",
          "value": "all"
        }
      },
      {
        "name": "bead_id",
        "label": "Bead",
        "type": "query",
        "datasource": {
          "uid": "dolt-beads"
        },
        "query": "SELECT id AS __value, CONCAT(LEFT(title, 70), ' [', issue_type, ' / ', status, ']') AS __text FROM ${database}.issues WHERE ('${filter}' = 'all' OR issue_type = '${filter}') ORDER BY CASE WHEN status IN ('open','in_progress','hooked','ready') THEN 0 ELSE 1 END, updated_at DESC LIMIT 200",
        "refresh": 1,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Identity",
      "type": "table",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT id, title, issue_type AS type, status, priority, COALESCE(NULLIF(assignee,''),'\u2014') AS assignee, COALESCE(NULLIF(owner,''),'\u2014') AS owner, COALESCE(NULLIF(rig,''),'\u2014') AS rig, work_type, mol_type FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View in Graph",
                    "url": "/d/gastown-bead-graph/gas-town-bead-graph?var-database=${database}&var-root_bead=${__value.raw}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "priority"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "id": "valueToText",
                    "options": {
                      "map": [
                        {
                          "text": "P0",
                          "value": "P0"
                        },
                        {
                          "text": "P1",
                          "value": "P1"
                        },
                        {
                          "text": "P2",
                          "value": "P2"
                        },
                        {
                          "text": "P3",
                          "value": "P3"
                        },
                        {
                          "text": "P4",
                          "value": "P4"
                        }
                      ]
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds",
                  "steps": [
                    {
                      "color": "red",
                      "text": "P0"
                    },
                    {
                      "color": "orange",
                      "text": "P1",
                      "value": 1
                    },
                    {
                      "color": "yellow",
                      "text": "P2",
                      "value": 2
                    },
                    {
                      "color": "blue",
                      "text": "P3",
                      "value": 3
                    },
                    {
                      "color": "grey",
                      "text": "P4",
                      "value": 4
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "type"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "id": "valueToText",
                    "options": {
                      "map": [
                        {
                          "text": "convoy",
                          "value": "convoy"
                        },
                        {
                          "text": "epic",
                          "value": "epic"
                        },
                        {
                          "text": "task",
                          "value": "task"
                        },
                        {
                          "text": "bug",
                          "value": "bug"
                        },
                        {
                          "text": "feature",
                          "value": "feature"
                        },
                        {
                          "text": "agent",
                          "value": "agent"
                        }
                      ]
                    }
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds",
                  "steps": [
                    {
                      "color": "red",
                      "text": "convoy"
                    },
                    {
                      "color": "purple",
                      "text": "epic",
                      "value": "epic"
                    },
                    {
                      "color": "green",
                      "text": "task",
                      "value": "task"
                    },
                    {
                      "color": "red",
                      "text": "bug",
                      "value": "bug"
                    },
                    {
                      "color": "blue",
                      "text": "feature",
                      "value": "feature"
                    },
                    {
                      "color": "orange",
                      "text": "agent",
                      "value": "agent"
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 2,
      "title": "Description",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT description FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "description"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 800
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": false,
        "cellHeight": "lg"
      }
    },
