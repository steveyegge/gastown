    {
      "id": 13,
      "title": "Events",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 61
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT created_at, event_type, COALESCE(NULLIF(actor,''),'\u2014') AS actor, old_value, new_value, LEFT(comment, 300) AS comment FROM ${database}.events WHERE issue_id = '${bead_id}' ORDER BY created_at ASC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ],
  "schemaVersion": 39
}
