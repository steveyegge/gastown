        "x": 0,
        "y": 12
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT acceptance_criteria FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
