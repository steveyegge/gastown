        "y": 51
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT created_at, COALESCE(NULLIF(author,''),'\u2014') AS author, text FROM ${database}.comments WHERE issue_id = '${bead_id}' ORDER BY created_at ASC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "lg"
      }
    },
    {
      "id": 23,
      "title": "",
