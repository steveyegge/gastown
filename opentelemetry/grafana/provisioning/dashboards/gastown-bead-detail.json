      "options": {
        "showHeader": false,
        "cellHeight": "lg"
      }
    },
    {
      "id": 5,
      "title": "Notes",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT notes FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "notes"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 800
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": false,
        "cellHeight": "lg"
      }
    },
    {
      "id": 6,
      "title": "Timestamps & Lifecycle",
      "type": "table",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT created_at, COALESCE(NULLIF(created_by,''),'\u2014') AS created_by, updated_at, closed_at, COALESCE(NULLIF(closed_by_session,''),'\u2014') AS closed_by, LEFT(close_reason, 200) AS close_reason, due_at, defer_until, last_activity, estimated_minutes FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 7,
      "title": "Agent & System",
      "type": "table",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(NULLIF(sender,''),'\u2014') AS sender, COALESCE(NULLIF(role_type,''),'\u2014') AS role_type, COALESCE(NULLIF(agent_state,''),'\u2014') AS agent_state, COALESCE(NULLIF(hook_bead,''),'\u2014') AS hook_bead, COALESCE(NULLIF(role_bead,''),'\u2014') AS role_bead, COALESCE(NULLIF(event_kind,''),'\u2014') AS event_kind, COALESCE(NULLIF(actor,''),'\u2014') AS actor, COALESCE(NULLIF(target,''),'\u2014') AS target, COALESCE(NULLIF(await_type,''),'\u2014') AS await_type, COALESCE(NULLIF(await_id,''),'\u2014') AS await_id, COALESCE(NULLIF(source_system,''),'\u2014') AS source_system, COALESCE(NULLIF(source_repo,''),'\u2014') AS source_repo, COALESCE(NULLIF(external_ref,''),'\u2014') AS external_ref FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "title": "Flags",
      "type": "table",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT ephemeral, pinned, is_template, crystallizes, quality_score, compaction_level, compacted_at, original_size, COALESCE(NULLIF(wisp_type,''),'\u2014') AS wisp_type, COALESCE(NULLIF(original_type,''),'\u2014') AS original_type FROM ${database}.issues WHERE id = '${bead_id}'",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 20,
      "title": "",
      "type": "text",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "options": {
        "mode": "markdown",
        "content": "## Labels"
      }
    },
    {
      "id": 9,
      "title": "Labels",
      "type": "table",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT label, created_at FROM ${database}.labels WHERE issue_id = '${bead_id}' ORDER BY label",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 21,
      "title": "",
      "type": "text",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "options": {
        "mode": "markdown",
        "content": "## Dependencies"
      }
    },
    {
      "id": 10,
      "title": "This bead depends on (parents / blockers)",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT d.type AS relationship, d.depends_on_id AS depends_on, COALESCE(p.title, d.depends_on_id) AS depends_on_title, COALESCE(p.status, '\u2014') AS depends_on_status, COALESCE(p.issue_type, '\u2014') AS depends_on_type FROM ${database}.dependencies d LEFT JOIN ${database}.issues p ON d.depends_on_id = p.id WHERE d.issue_id = '${bead_id}' ORDER BY d.type, d.depends_on_id",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "depends_on"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Bead",
                    "url": "/d/gastown-bead-detail/bead-detail?var-database=${database}&var-bead_id=${__value.raw}"
                  },
                  {
                    "title": "View in Graph",
                    "url": "/d/gastown-bead-graph/gas-town-bead-graph?var-database=${database}&var-root_bead=${__value.raw}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 11,
      "title": "Depends on this bead (children / blocked by this)",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "datasource": {
        "uid": "dolt-beads"
      },
      "targets": [
        {
          "rawSql": "SELECT d.type AS relationship, d.issue_id AS dependent, COALESCE(c.title, d.issue_id) AS dependent_title, COALESCE(c.status, '\u2014') AS dependent_status, COALESCE(c.issue_type, '\u2014') AS dependent_type FROM ${database}.dependencies d LEFT JOIN ${database}.issues c ON d.issue_id = c.id WHERE d.depends_on_id = '${bead_id}' ORDER BY d.type, d.issue_id",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "dependent"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Bead",
                    "url": "/d/gastown-bead-detail/bead-detail?var-database=${database}&var-bead_id=${__value.raw}"
                  },
                  {
                    "title": "View in Graph",
                    "url": "/d/gastown-bead-graph/gas-town-bead-graph?var-database=${database}&var-root_bead=${__value.raw}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
