{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Activity \u0026 Stuck Detection",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Per-role bd command rate. Zero activity for \u003e10 min suggests stuck agent.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(gastown_bd_calls_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "bd Call Rate by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "How actively agents are reading tmux output. Flat = idle or stuck.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(gastown_pane_reads_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "Pane Read Rate by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Agent sending prompts to its subprocess. Activity = working, silence = stuck or done.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(gastown_prompt_sends_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "Prompt Sends by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "State transitions (spawning -\u003e working -\u003e done). Stuck in one state too long = anomaly.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "targets": [
        {
          "expr": "increase(gastown_agent_state_changes_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m])",
          "legendFormat": "{{gt_role}} -\u003e {{new_state}}"
        }
      ],
      "title": "Agent State Changes",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 200,
      "title": "Error Rate \u0026 Anomaly Detection",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Rate of bd commands returning errors. Sustained errors = agent thrashing.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(gastown_bd_calls_total{status=\"error\", gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}} errors"
        }
      ],
      "title": "bd Error Rate by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Percentage of bd calls that fail. \u003e50% = agent is fighting something.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(gastown_bd_calls_total{status=\"error\", gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m])) / sum by (gt_role) (rate(gastown_bd_calls_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "bd Error Ratio by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Which bd subcommands are failing, per role.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (gt_role, subcommand) (rate(gastown_bd_calls_total{status=\"error\", gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}: {{subcommand}}"
        }
      ],
      "title": "bd Errors by Subcommand",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 300,
      "title": "Token \u0026 Cost Tracking",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Token consumption rate. Sudden spikes may indicate loops or excessive retries.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(claude_code_token_usage_tokens_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "Token Burn Rate by Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Dollar burn rate per agent role. High values warrant investigation.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(claude_code_cost_usage_USD_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m])) * 3600",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "Cost Rate by Role (USD/hr)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Token breakdown by model (opus/sonnet/haiku) per role.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "id": 10,
      "targets": [
        {
          "expr": "sum by (gt_role, model) (rate(claude_code_token_usage_tokens_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}} ({{model}})"
        }
      ],
      "title": "Token Usage by Model \u0026 Role",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Lines edited and edit tool decisions. Progress indicator for implementation work.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "id": 11,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(claude_code_lines_of_code_count_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}} lines"
        },
        {
          "expr": "sum by (gt_role) (rate(claude_code_code_edit_tool_decision_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}} edits"
        }
      ],
      "title": "Code Edits by Role",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 400,
      "title": "Summary Stats",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 52
      },
      "id": 12,
      "targets": [
        {
          "expr": "sum(claude_code_token_usage_tokens_total{gt_role=~\"$role\", gt_rig=~\"$rig\"})"
        }
      ],
      "title": "Total Tokens",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 52
      },
      "id": 13,
      "targets": [
        {
          "expr": "sum(claude_code_cost_usage_USD_total{gt_role=~\"$role\", gt_rig=~\"$rig\"})"
        }
      ],
      "title": "Total Cost",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 52
      },
      "id": 14,
      "targets": [
        {
          "expr": "sum(gastown_bd_calls_total{status=\"error\", gt_role=~\"$role\", gt_rig=~\"$rig\"})"
        }
      ],
      "title": "Total bd Errors",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 52
      },
      "id": 15,
      "targets": [
        {
          "expr": "sum(claude_code_commit_count_total{gt_role=~\"$role\", gt_rig=~\"$rig\"})"
        }
      ],
      "title": "Total Commits",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Per-role bd call latency. High latency may indicate Dolt contention.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 56
      },
      "id": 16,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (gt_role, le) (rate(gastown_bd_duration_ms_milliseconds_bucket{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m])))",
          "legendFormat": "{{gt_role}} p95"
        }
      ],
      "title": "bd Latency by Role (p95)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "description": "Claude Code active processing time per role.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 56
      },
      "id": 17,
      "targets": [
        {
          "expr": "sum by (gt_role) (rate(claude_code_active_time_seconds_total{gt_role=~\"$role\", gt_rig=~\"$rig\"}[5m]))",
          "legendFormat": "{{gt_role}}"
        }
      ],
      "title": "Active Time by Role",
      "type": "timeseries"
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": [
    "gastown",
    "agents",
    "health"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "uid": "victoriametrics"
        },
        "includeAll": true,
        "label": "Role",
        "multi": true,
        "name": "role",
        "query": "label_values(gastown_bd_calls_total, gt_role)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "uid": "victoriametrics"
        },
        "includeAll": true,
        "label": "Rig",
        "multi": true,
        "name": "rig",
        "query": "label_values(gastown_bd_calls_total, gt_rig)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-3d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Agent Health",
  "uid": "gastown-agent-health"
}
