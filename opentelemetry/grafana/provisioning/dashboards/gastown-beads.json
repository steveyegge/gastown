          "rawSql": "SELECT COALESCE(NULLIF(assignee, ''), 'unassigned') AS metric, COUNT(*) AS value FROM (SELECT assignee, status FROM hq.issues UNION ALL SELECT assignee, status FROM sfgastown.issues UNION ALL SELECT assignee, status FROM lora_forge.issues UNION ALL SELECT assignee, status FROM sf_workflows.issues) t WHERE status NOT IN ('closed') GROUP BY assignee ORDER BY value DESC LIMIT 15"
