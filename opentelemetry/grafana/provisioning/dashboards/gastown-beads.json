      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT DATE(created_at) AS time, rig, COUNT(*) AS value FROM (SELECT created_at, 'hq' AS rig FROM hq.issues UNION ALL SELECT created_at, 'sfgastown' FROM sfgastown.issues UNION ALL SELECT created_at, 'lora_forge' FROM lora_forge.issues UNION ALL SELECT created_at, 'sf_workflows' FROM sf_workflows.issues) t WHERE created_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY DATE(created_at), rig ORDER BY time"
        }
      ],
      "title": "Beads Created Over Time (all rigs)",
      "type": "timeseries"
    },
