      "id": 11,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT DATE(closed_at) AS time, rig, COUNT(*) AS value FROM (SELECT closed_at, 'hq' AS rig FROM hq.issues WHERE closed_at IS NOT NULL UNION ALL SELECT closed_at, 'sfgastown' FROM sfgastown.issues WHERE closed_at IS NOT NULL UNION ALL SELECT closed_at, 'lora_forge' FROM lora_forge.issues WHERE closed_at IS NOT NULL UNION ALL SELECT closed_at, 'sf_workflows' FROM sf_workflows.issues WHERE closed_at IS NOT NULL) t WHERE closed_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) GROUP BY DATE(closed_at), rig ORDER BY time"
        }
      ],
      "title": "Beads Closed Over Time (all rigs)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "id": 12,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT rig, SUM(created) AS created, SUM(closed) AS closed FROM (SELECT 'hq' AS rig, COUNT(*) AS created, 0 AS closed FROM hq.issues WHERE created_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'hq', 0, COUNT(*) FROM hq.issues WHERE closed_at IS NOT NULL AND closed_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'sfgastown', COUNT(*), 0 FROM sfgastown.issues WHERE created_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'sfgastown', 0, COUNT(*) FROM sfgastown.issues WHERE closed_at IS NOT NULL AND closed_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'lora_forge', COUNT(*), 0 FROM lora_forge.issues WHERE created_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'lora_forge', 0, COUNT(*) FROM lora_forge.issues WHERE closed_at IS NOT NULL AND closed_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'sf_workflows', COUNT(*), 0 FROM sf_workflows.issues WHERE created_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY) UNION ALL SELECT 'sf_workflows', 0, COUNT(*) FROM sf_workflows.issues WHERE closed_at IS NOT NULL AND closed_at \u003e= DATE_SUB(NOW(), INTERVAL 30 DAY)) t GROUP BY rig ORDER BY rig"
        }
      ],
      "title": "Created vs Closed per Rig (30d)",
      "type": "barchart"
    },
