        {
          "format": "table",
          "rawSql": "SELECT label AS metric, COUNT(*) AS value FROM (SELECT l.label, i.status FROM hq.labels l JOIN hq.issues i ON l.issue_id = i.id UNION ALL SELECT l.label, i.status FROM sfgastown.labels l JOIN sfgastown.issues i ON l.issue_id = i.id UNION ALL SELECT l.label, i.status FROM lora_forge.labels l JOIN lora_forge.issues i ON l.issue_id = i.id UNION ALL SELECT l.label, i.status FROM sf_workflows.labels l JOIN sf_workflows.issues i ON l.issue_id = i.id) t WHERE status NOT IN ('closed') GROUP BY label ORDER BY value DESC LIMIT 20"
