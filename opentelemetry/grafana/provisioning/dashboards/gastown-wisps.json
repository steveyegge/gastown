    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "description": "If oldest \u003e 24h and open count \u003e 500, reaper is likely not running",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "BEHIND": {
                  "color": "yellow",
                  "text": "BEHIND"
                },
                "OK": {
                  "color": "green",
                  "text": "OK"
                },
                "STALLED": {
                  "color": "red",
                  "text": "STALLED"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 2
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN COUNT(*) \u003e 500 AND MIN(created_at) \u003c DATE_SUB(NOW(), INTERVAL 24 HOUR) THEN 'STALLED' WHEN COUNT(*) \u003e 200 THEN 'BEHIND' ELSE 'OK' END AS value FROM hq.wisps WHERE status NOT IN ('closed') AND ephemeral = 1"
        }
      ],
      "title": "Reaper Status",
      "type": "stat"
    },
