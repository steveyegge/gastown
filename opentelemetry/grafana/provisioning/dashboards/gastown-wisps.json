      "id": 10,
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN TIMESTAMPDIFF(HOUR, created_at, NOW()) \u003c 1 THEN '1: \u003c 1h' WHEN TIMESTAMPDIFF(HOUR, created_at, NOW()) \u003c 4 THEN '2: 1-4h' WHEN TIMESTAMPDIFF(HOUR, created_at, NOW()) \u003c 24 THEN '3: 4-24h' WHEN TIMESTAMPDIFF(HOUR, created_at, NOW()) \u003c 72 THEN '4: 1-3d' WHEN TIMESTAMPDIFF(HOUR, created_at, NOW()) \u003c 168 THEN '5: 3-7d' ELSE '6: \u003e 7d' END AS age_bucket, COUNT(*) AS count FROM hq.wisps WHERE status NOT IN ('closed') AND ephemeral = 1 GROUP BY age_bucket ORDER BY age_bucket"
        }
      ],
      "title": "Open Wisps by Age",
      "type": "barchart"
