      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT d.depends_on_id AS parent, p.title AS parent_title, p.status AS parent_status, d.type AS relationship, d.issue_id AS child, c.title AS child_title, c.status AS child_status FROM ${database}.dependencies d LEFT JOIN ${database}.issues p ON d.depends_on_id = p.id LEFT JOIN ${database}.issues c ON d.issue_id = c.id WHERE ('${root_bead}' = '' OR d.depends_on_id = '${root_bead}' OR d.issue_id = '${root_bead}') ORDER BY d.depends_on_id, d.type, d.issue_id"
        }
      ],
