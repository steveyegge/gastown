{
  "panels": [
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "description": "Select a database and optionally enter a root bead ID to filter. Nodes = beads, edges = dependencies (parent-child, blocks).",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT i.id, CONCAT(i.issue_type, ': ', LEFT(i.title, 60)) AS title, i.status AS subtitle, CASE i.issue_type WHEN 'convoy' THEN 1.0 WHEN 'epic' THEN 0.8 ELSE 0.5 END AS mainstat FROM ${database}.issues i WHERE i.id IN (SELECT issue_id FROM ${database}.dependencies UNION SELECT depends_on_id FROM ${database}.dependencies)",
          "refId": "nodes"
        },
        {
          "format": "table",
          "rawSql": "SELECT CONCAT(d.depends_on_id, '-\u003e', d.issue_id) AS id, d.depends_on_id AS source, d.issue_id AS target, d.type AS mainstat FROM ${database}.dependencies d WHERE d.depends_on_id IN (SELECT id FROM ${database}.issues) AND d.issue_id IN (SELECT id FROM ${database}.issues)",
          "refId": "edges"
        }
      ],
      "title": "Dependency Graph",
      "type": "nodeGraph"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Focus in Graph",
                    "url": "/d/gastown-bead-graph/gas-town-bead-graph?var-database=${database}\u0026var-root_bead=${__value.raw}"
