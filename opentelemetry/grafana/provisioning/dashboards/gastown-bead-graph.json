        "multi": false,
        "name": "database",
        "query": "SELECT DISTINCT TABLE_SCHEMA AS __value, TABLE_SCHEMA AS __text FROM information_schema.TABLES WHERE TABLE_NAME = 'issues' ORDER BY TABLE_SCHEMA",
        "refresh": 1,
        "type": "query"
      },
      {
        "datasource": {
          "uid": "dolt-beads"
        },
        "includeAll": false,
        "label": "Bead",
        "name": "root_bead",
        "query": "SELECT id AS __value, CONCAT(LEFT(title, 80), ' [', issue_type, ' / ', status, ']') AS __text FROM ${database}.issues WHERE id IN (SELECT issue_id FROM ${database}.dependencies UNION SELECT depends_on_id FROM ${database}.dependencies) ORDER BY CASE issue_type WHEN 'convoy' THEN 0 WHEN 'epic' THEN 1 ELSE 2 END, priority ASC, created_at DESC",
