        "x": 0,
        "y": 20
      },
      "id": 2,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT i.id, i.title, i.issue_type, i.status, i.priority, COALESCE(NULLIF(i.assignee,''),'—') AS assignee, i.created_at, COALESCE(NULLIF(i.created_by,''),'—') AS created_by, LEFT(i.description, 500) AS description, LEFT(i.design, 300) AS design, LEFT(i.acceptance_criteria, 300) AS acceptance_criteria, LEFT(i.notes, 300) AS notes FROM ${database}.issues i WHERE ('${root_bead}' = '' OR i.id = '${root_bead}' OR i.id IN (SELECT issue_id FROM ${database}.dependencies WHERE depends_on_id = '${root_bead}') OR i.id IN (SELECT depends_on_id FROM ${database}.dependencies WHERE issue_id = '${root_bead}')) AND i.id IN (SELECT issue_id FROM ${database}.dependencies UNION SELECT depends_on_id FROM ${database}.dependencies) ORDER BY i.priority ASC LIMIT 50"
        }
      ],
      "title": "Bead Detail (select root bead above)",
      "type": "table"
    },
