      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT convoy.id AS convoy_id, LEFT(convoy.title, 80) AS convoy_title, convoy.status AS convoy_status, child.id AS child_id, LEFT(child.title, 80) AS child_title, child.issue_type AS child_type, child.status AS child_status, child.priority, COALESCE(NULLIF(child.assignee,''),'—') AS assignee FROM ${database}.dependencies d JOIN ${database}.issues convoy ON d.depends_on_id = convoy.id AND convoy.issue_type = 'convoy' JOIN ${database}.issues child ON d.issue_id = child.id WHERE d.type = 'parent-child' ORDER BY convoy.id, child.priority ASC"
