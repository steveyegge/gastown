{
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Session Overview",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(last_over_time(gastown_session_starts_total{gt_session=~\"lf-.*\", harness=~\"$harness\"}[7d])) - sum(last_over_time(gastown_session_stops_total{gt_session=~\"lf-.*\"}[7d]))",
          "legendFormat": "Active"
        }
      ],
      "title": "Active lf-* Sessions",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(last_over_time(gastown_done_total{gt_session=~\"lf-.*\", harness=~\"$harness\"}[7d]))",
          "legendFormat": "Done"
        }
      ],
      "title": "Total Done Events",
      "type": "stat"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(last_over_time(gastown_polecat_spawns_total{gt_rig=\"lora_forge\", harness=~\"$harness\"}[7d]))",
          "legendFormat": "Spawns"
        }
      ],
      "title": "Polecat Spawns",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 200,
      "title": "Session Outcomes (VictoriaLogs)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "exit_type"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "COMPLETED": {
                        "color": "green",
                        "text": "COMPLETED"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "DEFERRED": {
                        "color": "red",
                        "text": "DEFERRED"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "ESCALATED": {
                        "color": "orange",
                        "text": "ESCALATED"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "ok": {
                        "color": "green",
                        "text": "ok"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "error": {
                        "color": "red",
                        "text": "error"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 6
      },
      "id": 4,
      "targets": [
        {
          "expr": "_msg:\"done\" AND gt.rig:\"lora_forge\"",
          "refId": "A"
        }
      ],
      "title": "Recent Done Events",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "_time": true,
              "exit_type": true,
              "gt.role": true,
              "gt.session": true,
              "gt.topic": true,
              "status": true
            },
            "indexByName": {
              "_time": 0,
              "exit_type": 2,
              "gt.role": 5,
              "gt.session": 1,
              "gt.topic": 4,
              "status": 3
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "last_over_time(gastown_done_total{gt_session=~\"lf-.*\", harness=~\"$harness\"}[7d])",
          "legendFormat": "{{gt_session}} ({{exit_type}})"
        }
      ],
      "title": "Exit Type Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 300,
      "title": "Session Lifecycle",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 6,
      "targets": [
        {
          "expr": "increase(gastown_session_starts_total{gt_session=~\"lf-.*\", harness=~\"$harness\"}[$__rate_interval])",
          "legendFormat": "starts: {{gt_session}}"
        },
        {
          "expr": "increase(gastown_session_stops_total{gt_session=~\"lf-.*\", harness=~\"$harness\"}[$__rate_interval])",
          "legendFormat": "stops: {{gt_session}}"
        }
      ],
      "title": "Session Start/Stop Rate (lf-*)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "victorialogs"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 7,
      "targets": [
        {
          "expr": "(_msg:\"session.start\" OR _msg:\"session.stop\") AND gt.rig:\"lora_forge\"",
          "refId": "A"
        }
      ],
      "title": "Session Lifecycle Log",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "_msg": true,
              "_time": true,
              "rig": true,
              "role": true,
              "session_id": true
            },
            "indexByName": {
              "_msg": 1,
              "_time": 0,
              "rig": 4,
              "role": 3,
              "session_id": 2
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 400,
      "title": "Polecat Activity",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "id": 8,
      "targets": [
        {
          "expr": "increase(gastown_polecat_spawns_total{gt_rig=\"lora_forge\", harness=~\"$harness\"}[$__rate_interval])",
          "legendFormat": "spawn: {{gt_agent}}"
        },
        {
          "expr": "increase(gastown_polecat_removes_total{gt_rig=\"lora_forge\", harness=~\"$harness\"}[$__rate_interval])",
          "legendFormat": "remove: {{gt_agent}}"
        }
      ],
      "title": "Polecat Spawns/Removes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "id": 9,
      "targets": [
        {
          "expr": "rate(gastown_bd_calls_total{gt_rig=\"lora_forge\", harness=~\"$harness\"}[$__rate_interval])",
          "legendFormat": "{{subcommand}}"
        }
      ],
      "title": "bd Call Rate (lora_forge)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 500,
      "title": "Convoy Progress (Dolt)",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "open": {
                        "color": "yellow",
                        "text": "open"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "closed": {
                        "color": "green",
                        "text": "closed"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "in_progress": {
                        "color": "blue",
                        "text": "in_progress"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "id": 10,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT id, title, status, type, priority, assignee, COALESCE(closed_at, '') AS closed_at, created_at FROM lora_forge.issues ORDER BY CASE status WHEN 'open' THEN 0 WHEN 'in_progress' THEN 1 ELSE 2 END, created_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Lora Forge Beads",
      "type": "table"
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": [
    "gastown",
    "lora-forge"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "uid": "victoriametrics"
        },
        "includeAll": true,
        "multi": true,
        "name": "harness",
        "query": "label_values(gastown_session_starts_total{gt_rig=\"lora_forge\"}, harness)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Lora Forge Sessions",
  "uid": "lora-forge-sessions"
}
