            "desc": true,
            "displayName": "age_mins"
          }
        ]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT w.id, w.title, w.status,\n  CASE WHEN w.description LIKE '%worker: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'worker: ', -1), '\\n', 1) ELSE '—' END AS worker,\n  CASE WHEN w.description LIKE '%source_issue: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'source_issue: ', -1), '\\n', 1) ELSE '—' END AS source_issue,\n  SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'branch: ', -1), '\\n', 1) AS branch,\n  CASE WHEN w.description LIKE '%retry_count: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) ELSE '0' END AS retries,\n  w.created_at,\n  TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) AS age_mins,\n  CASE\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) \u003e 1440 AND (w.description NOT LIKE '%retry_count: %' OR SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) = '0') THEN 'DEAD'\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) \u003e 360 THEN 'STALE'\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) \u003e 60 THEN 'AGING'\n    ELSE 'OK'\n  END AS health\nFROM ${database}.wisps w\nJOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request'\nWHERE w.status = 'open'\nORDER BY age_mins DESC"
        }
      ],
      "title": "Open Merge Requests",
      "type": "table"
