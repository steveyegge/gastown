{
  "uid": "gastown-refinery",
  "title": "Refinery",
  "tags": ["gastown", "refinery", "merge"],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "database",
        "type": "query",
        "label": "Rig",
        "datasource": { "uid": "dolt-beads" },
        "query": "SELECT DISTINCT TABLE_SCHEMA AS __value, TABLE_SCHEMA AS __text FROM information_schema.TABLES WHERE TABLE_NAME = 'wisp_labels' AND TABLE_SCHEMA NOT LIKE 'beads%' ORDER BY TABLE_SCHEMA",
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "sfgastown",
          "value": "sfgastown"
        },
        "refresh": 1
      },
      {
        "name": "convoy_id",
        "type": "query",
        "label": "Convoy",
        "datasource": { "uid": "dolt-beads" },
        "query": "SELECT id AS __value, CONCAT(LEFT(title, 60), ' [', status, ']') AS __text FROM hq.issues WHERE issue_type = 'convoy' ORDER BY CASE WHEN status IN ('open','in_progress') THEN 0 ELSE 1 END, updated_at DESC LIMIT 100",
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 50,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Stuck Detection"
      }
    },
    {
      "id": 51,
      "title": "Stale MRs (>6h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS stale FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open' AND w.created_at < NOW() - INTERVAL 6 HOUR",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 52,
      "title": "Hours Since Last Merge",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ROUND(TIMESTAMPDIFF(MINUTE, MAX(w.created_at), NOW()) / 60.0, 1), 999) AS hours_since FROM hq.wisps w WHERE w.title LIKE 'MERGED %'",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 12 }
            ]
          }
        }
      }
    },
    {
      "id": 53,
      "title": "Zero-Retry Stuck MRs",
      "description": "Open MRs older than 1h with retry_count=0 — refinery never touched them",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS stuck FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open' AND w.created_at < NOW() - INTERVAL 1 HOUR AND (w.description NOT LIKE '%retry_count: %' OR SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) = '0')",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 54,
      "title": "Refinery Last Seen (hours)",
      "description": "Hours since last refinery bd call in VictoriaMetrics. Red if >4h = refinery likely dead.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "(time() - max(timestamp(gastown_bd_calls_total{gt_role=~\".*refinery.*\"}))) / 3600",
          "legendFormat": "hours ago"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "id": 55,
      "title": "Refinery Health",
      "description": "MR queue health for the selected rig",
      "type": "table",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 6 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT '${database}' AS rig, COUNT(*) AS open_mrs, SUM(CASE WHEN w.created_at < NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) AS stale_mrs, COALESCE(CONCAT(ROUND(MAX(TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) / 60.0), 1), 'h'), '—') AS oldest_mr, COALESCE(MAX(CASE WHEN w.description LIKE '%retry_count: %' THEN CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) AS UNSIGNED) ELSE 0 END), 0) AS max_retries, CASE WHEN COUNT(*) = 0 THEN 'OK' WHEN SUM(CASE WHEN w.created_at < NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) > 0 AND MAX(CASE WHEN w.description LIKE '%retry_count: %' THEN CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) AS UNSIGNED) ELSE 0 END) = 0 THEN 'DEAD' WHEN SUM(CASE WHEN w.created_at < NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) > 0 THEN 'STALE' WHEN MAX(TIMESTAMPDIFF(MINUTE, w.created_at, NOW())) > 60 THEN 'AGING' ELSE 'OK' END AS health FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open'",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "health" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "OK": { "color": "green", "text": "OK" },
                      "AGING": { "color": "yellow", "text": "AGING" },
                      "STALE": { "color": "orange", "text": "STALE" },
                      "DEAD": { "color": "red", "text": "DEAD" }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stale_mrs" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      }
    },
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 11 },
      "options": {
        "mode": "markdown",
        "content": "## MR Queue Overview"
      }
    },
    {
      "id": 2,
      "title": "Open MRs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 13 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS open_mrs FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open'",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Merged (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 13 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS merged_24h FROM hq.wisps w WHERE w.title LIKE 'MERGED %' AND w.created_at >= NOW() - INTERVAL 24 HOUR",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Failed/Rejected (7d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 13 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS failed FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'closed' AND w.created_at >= NOW() - INTERVAL 7 DAY",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Avg MR Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 13 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(CONCAT(ROUND(AVG(TIMESTAMPDIFF(MINUTE, w.created_at, NOW()))), 'm'), '—') AS avg_age FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open'",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Oldest MR",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 13 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(CONCAT(ROUND(MAX(TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) / 60.0), 1), 'h'), '—') AS oldest FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open'",
          "format": "table"
        }
      ],
      "options": {
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 72 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 17 },
      "options": {
        "mode": "markdown",
        "content": "## MR Queue"
      }
    },
    {
      "id": 11,
      "title": "Open Merge Requests",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT w.id, w.title, w.status,\n  CASE WHEN w.description LIKE '%worker: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'worker: ', -1), '\\n', 1) ELSE '—' END AS worker,\n  CASE WHEN w.description LIKE '%source_issue: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'source_issue: ', -1), '\\n', 1) ELSE '—' END AS source_issue,\n  SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'branch: ', -1), '\\n', 1) AS branch,\n  CASE WHEN w.description LIKE '%retry_count: %' THEN SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) ELSE '0' END AS retries,\n  w.created_at,\n  TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) AS age_mins,\n  CASE\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) > 1440 AND (w.description NOT LIKE '%retry_count: %' OR SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) = '0') THEN 'DEAD'\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) > 360 THEN 'STALE'\n    WHEN TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) > 60 THEN 'AGING'\n    ELSE 'OK'\n  END AS health\nFROM ${database}.wisps w\nJOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request'\nWHERE w.status = 'open'\nORDER BY age_mins DESC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "age_mins", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source_issue" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Bead Detail",
                    "url": "/d/gastown-bead-detail/bead-detail?var-database=${database}&var-bead_id=${__value.raw}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "age_mins" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 60 },
                    { "color": "red", "value": 1440 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "health" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "OK": { "color": "green", "text": "OK" },
                      "AGING": { "color": "yellow", "text": "AGING" },
                      "STALE": { "color": "orange", "text": "STALE" },
                      "DEAD": { "color": "red", "text": "DEAD" }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "open": { "color": "blue", "text": "open" },
                      "closed": { "color": "red", "text": "closed" }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      }
    },
    {
      "id": 20,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 29 },
      "options": {
        "mode": "markdown",
        "content": "## Recent Merges"
      }
    },
    {
      "id": 21,
      "title": "Completed Merges",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT w.id,\n  w.title,\n  SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'Branch: ', -1), '\\n', 1) AS branch,\n  SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'Issue: ', -1), '\\n', 1) AS source_issue,\n  SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'Merged-At: ', -1), '\\n', 1) AS merged_at,\n  w.created_at\nFROM hq.wisps w\nWHERE w.title LIKE 'MERGED %'\nORDER BY w.created_at DESC\nLIMIT 50",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "created_at", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source_issue" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Bead Detail",
                    "url": "/d/gastown-bead-detail/bead-detail?var-database=hq&var-bead_id=${__value.raw}"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 30,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 41 },
      "options": {
        "mode": "markdown",
        "content": "## Merge Activity"
      }
    },
    {
      "id": 31,
      "title": "gt done Rate (by rig + harness)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (gt_rig, gt_harness) (increase(gastown_done_total[5m]))",
          "legendFormat": "{{gt_rig}} / {{gt_harness}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 32,
      "title": "Bead Call Rate (by subcommand + harness)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (subcommand, gt_harness) (rate(gastown_bd_calls_total{subcommand=~\"done|hook|close|update\"}[5m]))",
          "legendFormat": "{{subcommand}} / {{gt_harness}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 33,
      "title": "Merge Signals",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT\n  CASE\n    WHEN title LIKE 'MERGE_READY:%' THEN 'MERGE_READY'\n    WHEN title LIKE 'MERGED %' THEN 'MERGED'\n    ELSE 'Other'\n  END AS signal_type,\n  COUNT(*) AS cnt\nFROM hq.wisps\nWHERE title LIKE 'MERGE%'\nGROUP BY signal_type",
          "format": "table"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "reduceOptions": {
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 43,
      "title": "Merges Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 51 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT\n  w.created_at AS time,\n  TRIM(REPLACE(w.title, 'MERGED ', '')) AS worker,\n  1 AS merges\nFROM hq.wisps w\nWHERE w.title LIKE 'MERGED %'\n  AND w.created_at >= NOW() - INTERVAL 7 DAY\nORDER BY w.created_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "showPoints": "always"
          }
        }
      }
    },
    {
      "id": 34,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 59 },
      "options": {
        "mode": "markdown",
        "content": "## Refinery Agent Activity"
      }
    },
    {
      "id": 35,
      "title": "Refinery bd Calls (by subcommand + harness)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (subcommand, gt_harness) (rate(gastown_bd_calls_total{gt_role=~\".*refinery.*\"}[5m]))",
          "legendFormat": "{{subcommand}} / {{gt_harness}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 36,
