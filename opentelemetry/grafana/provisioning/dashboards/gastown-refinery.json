      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS stuck FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open' AND w.created_at \u003c NOW() - INTERVAL 1 HOUR AND (w.description NOT LIKE '%retry_count: %' OR SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) = '0')"
        }
      ],
      "title": "Zero-Retry Stuck MRs",
      "type": "stat"
    },
    {
