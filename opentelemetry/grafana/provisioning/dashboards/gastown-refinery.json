    {
      "id": 41,
      "title": "MR Breakdown",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 101 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT SUM(CASE WHEN w.status = 'open' THEN 1 ELSE 0 END) AS open_mrs, SUM(CASE WHEN w.status = 'closed' THEN 1 ELSE 0 END) AS closed_mrs, COUNT(*) AS total FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request'",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 42,
      "title": "Merges per Worker",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 101 },
      "datasource": { "uid": "dolt-beads" },
      "targets": [
        {
          "rawSql": "SELECT\n  TRIM(REPLACE(REPLACE(w.title, 'MERGED ', ''), 'MERGED', '')) AS worker,\n  COUNT(*) AS merge_count\nFROM hq.wisps w\nWHERE w.title LIKE 'MERGED %'\nGROUP BY worker\nORDER BY merge_count DESC",
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "merge_count", "desc": true }]
      }
    }
