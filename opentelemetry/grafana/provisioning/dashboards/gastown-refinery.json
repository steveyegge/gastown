      "type": "stat"
    },
    {
      "datasource": {
        "uid": "dolt-beads"
      },
      "description": "MR queue health for the selected rig",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "health"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "AGING": {
                        "color": "yellow",
                        "text": "AGING"
                      },
                      "DEAD": {
                        "color": "red",
                        "text": "DEAD"
                      },
                      "OK": {
                        "color": "green",
                        "text": "OK"
                      },
                      "STALE": {
                        "color": "orange",
                        "text": "STALE"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "stale_mrs"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 55,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT '${database}' AS rig, COUNT(*) AS open_mrs, SUM(CASE WHEN w.created_at \u003c NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) AS stale_mrs, COALESCE(CONCAT(ROUND(MAX(TIMESTAMPDIFF(MINUTE, w.created_at, NOW()) / 60.0), 1), 'h'), '—') AS oldest_mr, COALESCE(MAX(CASE WHEN w.description LIKE '%retry_count: %' THEN CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) AS UNSIGNED) ELSE 0 END), 0) AS max_retries, CASE WHEN COUNT(*) = 0 THEN 'OK' WHEN SUM(CASE WHEN w.created_at \u003c NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) \u003e 0 AND MAX(CASE WHEN w.description LIKE '%retry_count: %' THEN CAST(SUBSTRING_INDEX(SUBSTRING_INDEX(w.description, 'retry_count: ', -1), '\\n', 1) AS UNSIGNED) ELSE 0 END) = 0 THEN 'DEAD' WHEN SUM(CASE WHEN w.created_at \u003c NOW() - INTERVAL 6 HOUR THEN 1 ELSE 0 END) \u003e 0 THEN 'STALE' WHEN MAX(TIMESTAMPDIFF(MINUTE, w.created_at, NOW())) \u003e 60 THEN 'AGING' ELSE 'OK' END AS health FROM ${database}.wisps w JOIN ${database}.wisp_labels wl ON wl.issue_id = w.id AND wl.label = 'gt:merge-request' WHERE w.status = 'open'"
        }
      ],
      "title": "Refinery Health",
      "type": "table"
    },
