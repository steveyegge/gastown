{
  "panels": [
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "increase(gastown_session_starts_total{role=~\"$role\", harness=~\"$harness\"}[5m])",
          "legendFormat": "{{role}}"
        }
      ],
      "title": "Session Starts",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "increase(gastown_daemon_agent_restarts_total[5m])",
          "legendFormat": "{{agent_type}}"
        }
      ],
      "title": "Daemon Agent Restarts",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "rate(gastown_bd_calls_total{subcommand=~\"$subcommand\"}[5m])",
          "legendFormat": "{{subcommand}} ({{status}})"
        }
      ],
      "title": "bd Call Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "bd Call Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "uid": "victoriametrics"
      },
