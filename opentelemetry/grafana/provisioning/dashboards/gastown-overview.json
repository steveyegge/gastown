{
  "uid": "gastown-overview",
  "title": "Gas Town Overview",
  "tags": ["gastown"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "role",
        "type": "query",
        "datasource": { "uid": "victoriametrics" },
        "query": "label_values(gastown_session_starts_total, role)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "subcommand",
        "type": "query",
        "datasource": { "uid": "victoriametrics" },
        "query": "label_values(gastown_bd_calls_total, subcommand)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Session Starts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "increase(gastown_session_starts_total{role=~\"$role\"}[5m])",
          "legendFormat": "{{role}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 2,
      "title": "Daemon Agent Restarts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "increase(gastown_daemon_agent_restarts_total[5m])",
          "legendFormat": "{{agent_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "bd Call Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "rate(gastown_bd_calls_total{subcommand=~\"$subcommand\"}[5m])",
          "legendFormat": "{{subcommand}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "bd Call Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(gastown_bd_duration_ms_milliseconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 5,
      "title": "Mail Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "increase(gastown_mail_operations_total[5m])",
          "legendFormat": "{{operation}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 6,
      "title": "Polecat Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "increase(gastown_polecat_spawns_total[5m])",
          "legendFormat": "spawns"
        },
        {
          "expr": "increase(gastown_polecat_removes_total[5m])",
          "legendFormat": "removes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 7,
      "title": "Sling Dispatches & Prime Invocations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "increase(gastown_sling_dispatches_total[5m])",
          "legendFormat": "slings"
        },
        {
          "expr": "increase(gastown_prime_total[5m])",
          "legendFormat": "primes ({{role}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 8,
      "title": "Active Sessions (current)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(gastown_session_starts_total{status=\"ok\"}) - sum(gastown_session_stops_total{status=\"ok\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Total bd Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(gastown_bd_calls_total)"
        }
      ]
    },
    {
      "id": 10,
      "title": "Total Mail Operations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(gastown_mail_operations_total)"
        }
      ]
    },
    {
      "id": 11,
      "title": "Daemon Restarts (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(gastown_daemon_agent_restarts_total)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Dolt Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "gastown_dolt_connections",
          "legendFormat": "active connections"
        },
        {
          "expr": "gastown_dolt_max_connections",
          "legendFormat": "max connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 13,
      "title": "Dolt Disk Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "gastown_dolt_disk_usage_bytes",
          "legendFormat": "disk usage"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
