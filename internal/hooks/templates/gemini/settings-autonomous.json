{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "Bash\\(gh pr create.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash\\(git checkout -b.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash\\(git switch -c.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash\\(git push.*main.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "GT_SESSION_ID=${GT_SESSION_ID:-$(uuidgen)} GT_HOOK_SOURCE=startup {{GT_BIN}} prime --hook && {{GT_BIN}} mail check --inject"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "GT_HOOK_SOURCE=compact {{GT_BIN}} prime --hook"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} mail check --inject"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} costs record &"
          }
        ]
      }
    ]
  }
}
