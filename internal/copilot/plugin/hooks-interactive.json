{
  "version": 1,
  "x-gastown-managed": true,
  "hooks": {
    "sessionStart": [{
      "type": "command",
      "bash": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt prime --hook",
      "timeoutSec": 30
    }],
    "userPromptSubmitted": [{
      "type": "command",
      "bash": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt mail check --inject",
      "timeoutSec": 10
    }],
    "preToolUse": [{
      "type": "command",
      "bash": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && .github/hooks/gastown-pretool-guard.sh",
      "timeoutSec": 10
    }],
    "sessionEnd": [{
      "type": "command",
      "bash": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$HOME/bin:$PATH\" && gt costs record",
      "timeoutSec": 10
    }]
  }
}
